  \
  const [createDelivery, setCreateDelivery] = useState(true);\
\
  useEffect(() => \{\
    if (!user) return;\
    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'invoice_app', 'main_state');\
    const unsubscribe = onSnapshot(docRef, (docSnap) => \{\
      if (docSnap.exists()) \{\
        const data = docSnap.data();\
        if (data.menuItems && data.menuItems.length > 0) setMenuItems(data.menuItems);\
        if (data.invoices) \{\
            setInvoices(data.invoices);\
            setInvoiceData(prev => (\{ ...prev, invoiceNo: getNextInvoiceNo(data.invoices) \}));\
