    \});\
    return () => unsubscribe();\
  \}, [user]);\
\
  const handleExportPDF = (elementId, filename) => \{\
    showToast("Generating Invoice PDF...");\
    setIsExporting(true);\
    setTimeout(() => \{\
      const element = document.getElementById(elementId);\
      const opt = \{ margin: [0.5, 0.5, 0.5, 0.5], filename: `$\{filename\}.pdf`, image: \{ type: 'jpeg', quality: 1 \}, html2canvas: \{ scale: 2, useCORS: true \}, jsPDF: \{ unit: 'in', format: 'a4', orientation: 'portrait' \} \};\
      const generate = () => \{\
        window.html2pdf().set(opt).from(element).save().then(() => \{ setIsExporting(false); showToast("PDF Downloaded!"); \}).catch(err => setIsExporting(false));\
