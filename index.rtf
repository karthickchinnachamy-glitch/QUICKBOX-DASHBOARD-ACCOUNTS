\
  const [invoiceData, setInvoiceData] = useState(\{\
    invoiceNo: 'INV-1001', date: new Date().toISOString().split('T')[0], customerName: '', customerPhone: '', customerAddress: '', items: [], taxRate: 5, discount: 0\
  \});\
