  if (fromUnit === 'kg' && toUnit === 'g') return qty * 1000;\
  if (fromUnit === 'ml' && toUnit === 'L') return qty / 1000;\
  if (fromUnit === 'L' && toUnit === 'ml') return qty * 1000;\
  return qty;\
\};\
