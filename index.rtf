// MODULE 3: DELIVERY TRACKING\
// ==========================================\
const DeliveryModule = (\{ user, showToast \}) => \{\
  const [activeTab, setActiveTab] = useState('active');\
  const [deliveries, setDeliveries] = useState([]);\
  const [isSaving, setIsSaving] = useState(false);\
  const [newDelivery, setNewDelivery] = useState(\{ orderId: generateOrderId(), customerName: '', phone: '', address: '', platform: 'Direct Order', amount: '', driverName: '' \});\
\
  useEffect(() => \{\
    if (!user) return;\
    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'delivery_app', 'main_state');\
    const unsubscribe = onSnapshot(docRef, (docSnap) => \{ if (docSnap.exists()) setDeliveries(docSnap.data().deliveries || []); \});\
    return () => unsubscribe();\
  \}, [user]);\
\
  const handleSaveToCloud = async () => \{\
    if (!user) return;\
    setIsSaving(true);\
    try \{\
      await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'delivery_app', 'main_state'), \{ deliveries, lastUpdated: new Date().toISOString() \});\
      showToast("Delivery tracking saved!");\
    \} catch (err) \{ showToast("Error saving."); \}\
    setIsSaving(false);\
  \};\
\
  const updateStatus = async (id, newStatus) => \{\
    const updated = deliveries.map(d => d.id === id ? \{ ...d, status: newStatus, timeUpdated: new Date().toLocaleTimeString() \} : d);\
    setDeliveries(updated);\
    if (user) \{\
        await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'delivery_app', 'main_state'), \{ deliveries: updated, lastUpdated: new Date().toISOString() \}, \{merge: true\});\
    \}\
    showToast(`Order marked as $\{newStatus\}`);\
  \};\
\
  const renderActiveDeliveries = () => \{\
    const activeList = deliveries.filter(d => d.status === 'Pending' || d.status === 'On the Way');\
    return (\
      <div className="p-4 sm:p-6 max-w-6xl mx-auto space-y-6">\
