            <div className="bg-white rounded-xl border border-dashed border-slate-300 p-12 text-center text-slate-400"><Truck className="w-12 h-12 mx-auto mb-3 text-slate-300" /><p className="font-medium text-lg text-slate-500">No active deliveries.</p></div>\
        ) : (\
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">\
                \{activeList.map(order => (\
                    <div key=\{order.id\} className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">\
                        <div className=\{`px-4 py-3 border-b flex justify-between items-center $\{order.status === 'On the Way' ? 'bg-indigo-50' : 'bg-slate-50'\}`\}>\
                            <span className="font-black text-slate-700">\{order.orderId\}</span>\
                            <span className=\{`text-xs font-bold px-2.5 py-1 rounded-full $\{order.status === 'On the Way' ? 'bg-indigo-100 text-indigo-700' : 'bg-amber-100 text-amber-700'\}`\}>\{order.status\}</span>\
                        </div>\
                        <div className="p-4 flex-1 space-y-3">\
                            <div className="flex items-start gap-2"><User className="w-4 h-4 text-slate-400 shrink-0 mt-0.5" /><div><p className="font-bold text-slate-800 text-sm leading-tight">\{order.customerName\}</p><p className="text-[10px] uppercase font-bold tracking-wider text-slate-500 bg-slate-100 px-2 py-0.5 rounded mt-1 inline-block">\{order.platform\}</p></div></div>\
                            <div className="flex items-start gap-2"><Phone className="w-4 h-4 text-slate-400 shrink-0 mt-0.5" /><p className="font-medium text-slate-600 text-sm">\{order.phone || 'N/A'\}</p></div>\
                            <div className="flex items-start gap-2"><MapPin className="w-4 h-4 text-slate-400 shrink-0 mt-0.5" /><p className="font-medium text-slate-600 text-sm leading-snug">\{order.address\}</p></div>\
                            <div className="pt-3 mt-1 border-t border-slate-100 flex justify-between items-center"><span className="text-xs text-slate-400 flex items-center font-medium"><Clock className="w-3 h-3 mr-1"/> \{order.timeAdded\}</span><span className="font-black text-orange-600 text-lg">\uc0\u8377 \{parseFloat(order.amount).toFixed(2)\}</span></div>\
                        </div>\
                        <div className="p-3 bg-slate-50 border-t border-slate-100 flex gap-2">\
                            \{order.status === 'Pending' && <button onClick=\{() => updateStatus(order.id, 'On the Way')\} className="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold py-2.5 rounded-lg transition-colors flex items-center justify-center gap-2"><Navigation className="w-4 h-4"/> Start</button>\}\
                            \{order.status === 'On the Way' && <button onClick=\{() => updateStatus(order.id, 'Delivered')\} className="flex-1 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-bold py-2.5 rounded-lg transition-colors flex items-center justify-center gap-2"><Check className="w-4 h-4"/> Delivered</button>\}\
                        </div>\
                    </div>\
                ))\}\
            </div>\
        )\}\
      </div>\
    );\
  \};\
\
  const renderAddDelivery = () => \{\
    return (\
      <div className="p-4 sm:p-6 max-w-3xl mx-auto">\
        <div className="bg-white rounded-xl shadow-md border border-slate-200 overflow-hidden">\
            <div className="bg-slate-800 px-6 py-5 border-b border-slate-700 flex items-center gap-3">\
                <div className="bg-orange-500 p-2 rounded-lg text-white"><Plus className="w-5 h-5"/></div>\
                <h2 className="text-xl font-bold text-white">New Delivery Task</h2>\
            </div>\
            <div className="p-6 space-y-6">\
                <div className="grid grid-cols-2 gap-6">\
                    <div><label className="block text-xs font-bold text-slate-500 mb-1">Order ID</label><input type="text" className="w-full rounded-lg border-slate-300 border p-2 outline-none focus:ring-2 focus:ring-orange-500" value=\{newDelivery.orderId\} onChange=\{(e) => setNewDelivery(\{...newDelivery, orderId: e.target.value\})\} /></div>\
                    <div><label className="block text-xs font-bold text-slate-500 mb-1">Platform</label><select className="w-full rounded-lg border-slate-300 border p-2 outline-none focus:ring-2 focus:ring-orange-500" value=\{newDelivery.platform\} onChange=\{(e) => setNewDelivery(\{...newDelivery, platform: e.target.value\})\}><option>Direct Order</option><option>Swiggy</option><option>Zomato</option></select></div>\
                </div>\
                <div className="grid grid-cols-2 gap-6">\
                    <div><label className="block text-xs font-bold text-slate-500 mb-1">Customer Name</label><input type="text" className="w-full rounded-lg border-slate-300 border p-2 outline-none focus:ring-2 focus:ring-orange-500" value=\{newDelivery.customerName\} onChange=\{(e) => setNewDelivery(\{...newDelivery, customerName: e.target.value\})\} /></div>\
                    <div><label className="block text-xs font-bold text-slate-500 mb-1">Phone Number</label><input type="text" className="w-full rounded-lg border-slate-300 border p-2 outline-none focus:ring-2 focus:ring-orange-500" value=\{newDelivery.phone\} onChange=\{(e) => setNewDelivery(\{...newDelivery, phone: e.target.value\})\} /></div>\
                </div>\
                <div><label className="block text-xs font-bold text-slate-500 mb-1">Delivery Address</label><textarea className="w-full rounded-lg border-slate-300 border p-2 outline-none focus:ring-2 focus:ring-orange-500 resize-none" rows="2" value=\{newDelivery.address\} onChange=\{(e) => setNewDelivery(\{...newDelivery, address: e.target.value\})\} /></div>\
                <div className="grid grid-cols-2 gap-6">\
                    <div><label className="block text-xs font-bold text-slate-500 mb-1">Driver Name</label><input type="text" className="w-full rounded-lg border-slate-300 border p-2 outline-none focus:ring-2 focus:ring-orange-500" value=\{newDelivery.driverName\} onChange=\{(e) => setNewDelivery(\{...newDelivery, driverName: e.target.value\})\} /></div>\
                    <div><label className="block text-xs font-bold text-slate-500 mb-1">Amount (\uc0\u8377 )</label><input type="number" className="w-full rounded-lg border-slate-300 border p-2 outline-none focus:ring-2 focus:ring-orange-500" value=\{newDelivery.amount\} onChange=\{(e) => setNewDelivery(\{...newDelivery, amount: e.target.value\})\} /></div>\
                </div>\
                <button onClick=\{async () => \{ if(!newDelivery.customerName) return; const updated = [\{...newDelivery, id: Date.now(), amount: parseFloat(newDelivery.amount)||0, status: 'Pending', timeAdded: new Date().toLocaleTimeString([], \{hour: '2-digit', minute:'2-digit'\})\}, ...deliveries]; setDeliveries(updated); if(user)\{ await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'delivery_app', 'main_state'), \{ deliveries: updated, lastUpdated: new Date().toISOString() \}, \{merge: true\}); \} showToast("Task Added"); setNewDelivery(\{orderId: generateOrderId(), customerName:'', phone:'', address:'', platform:'Direct Order', amount:'', driverName:''\}); \}\} className="w-full bg-orange-600 hover:bg-orange-700 text-white py-3 rounded-lg font-bold mt-4">Create Task</button>\
            </div>\
        </div>\
      </div>\
    );\
  \};\
\
  const renderHistory = () => \{\
    return (\
      <div className="p-4 sm:p-6 max-w-6xl mx-auto">\
        <div className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">\
          <div className="bg-slate-800 px-6 py-5"><h2 className="text-xl font-bold text-white flex items-center gap-2"><History className="w-5 h-5 text-orange-400" /> Completed Deliveries</h2></div>\
          <div className="overflow-x-auto">\
            <table className="w-full text-left border-collapse min-w-[800px]">\
              <thead className="bg-slate-50 border-b border-slate-200 text-slate-600 text-xs uppercase">\
                <tr>\
                  <th className="p-4">ID / Time</th>\
                  <th className="p-4">Customer</th>\
                  <th className="p-4">Address</th>\
                  <th className="p-4 text-center">Driver Name</th>\
                  <th className="p-4 text-right">Amount</th>\
                  <th className="p-4 text-right">Action</th>\
                </tr>\
              </thead>\
              <tbody>\
                \{deliveries.filter(d => d.status === 'Delivered').map((order) => (\
                  <tr key=\{order.id\} className="border-b border-slate-100 hover:bg-slate-50">\
                    <td className="p-4"><div className="font-bold text-slate-800">\{order.orderId\}</div><div className="text-xs text-slate-500">\{order.timeUpdated\}</div></td>\
                    <td className="p-4"><div className="font-bold text-slate-700">\{order.customerName\}</div><div className="text-xs text-slate-500">\{order.phone\}</div></td>\
                    <td className="p-4 text-sm text-slate-600 max-w-[200px] truncate" title=\{order.address\}>\{order.address\}</td>\
                    <td className="p-4 text-center text-sm font-medium">\{order.driverName || '-'\}</td>\
                    <td className="p-4 text-right font-bold text-slate-800">\uc0\u8377 \{parseFloat(order.amount).toFixed(2)\}</td>\
                    <td className="p-4 text-right"><button onClick=\{async () => \{ const up = deliveries.filter(d => d.id !== order.id); setDeliveries(up); if(user)\{ await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'delivery_app', 'main_state'), \{ deliveries: up, lastUpdated: new Date().toISOString() \}, \{merge:true\}); \} showToast("Deleted."); \}\} className="text-red-400 hover:text-red-600 p-2"><Trash2 className="w-4 h-4"/></button></td>\
                  </tr>\
                ))\}\
                \{deliveries.filter(d => d.status === 'Delivered').length === 0 && (\
                    <tr><td colSpan=\{6\} className="p-12 text-center text-slate-400 italic">No completed deliveries yet.</td></tr>\
                )\}\
              </tbody>\
            </table>\
          </div>\
        </div>\
      </div>\
    );\
  \};\
\
  return (\
    <div className="flex-1 flex flex-col h-full overflow-auto">\
      <header className="bg-white border-b border-slate-200 sticky top-0 z-10 shrink-0">\
        <div className="px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between h-auto py-3 gap-4">\
            <nav className="flex gap-1 w-full sm:w-auto overflow-x-auto justify-center sm:justify-start">\
              <button onClick=\{() => setActiveTab('active')\} className=\{`px-3 py-2 rounded-md text-sm font-medium flex items-center gap-2 $\{activeTab === 'active' ? 'bg-orange-50 text-orange-700' : 'text-slate-600 hover:bg-slate-50'\}`\}><MapPin className="w-4 h-4"/> Active</button>\
              <button onClick=\{() => setActiveTab('add')\} className=\{`px-3 py-2 rounded-md text-sm font-medium flex items-center gap-2 $\{activeTab === 'add' ? 'bg-orange-50 text-orange-700' : 'text-slate-600 hover:bg-slate-50'\}`\}><Plus className="w-4 h-4"/> Add Task</button>\
              <button onClick=\{() => setActiveTab('history')\} className=\{`px-3 py-2 rounded-md text-sm font-medium flex items-center gap-2 $\{activeTab === 'history' ? 'bg-orange-50 text-orange-700' : 'text-slate-600 hover:bg-slate-50'\}`\}><History className="w-4 h-4"/> History</button>\
            </nav>\
            <button onClick=\{handleSaveToCloud\} disabled=\{isSaving\} className="flex items-center gap-2 px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded-lg"><Save className="w-4 h-4"/> \{isSaving ? '...' : 'Sync Data'\}</button>\
        </div>\
      </header>\
      <div className="flex-1">\
        \{activeTab === 'active' && renderActiveDeliveries()\}\
        \{activeTab === 'add' && renderAddDelivery()\}\
        \{activeTab === 'history' && renderHistory()\}\
      </div>\
    </div>\
  );\
\};\
\
// ==========================================\
// MAIN APP WRAPPER (SIDEBAR + CONTENT)\
// ==========================================\
const App = () => \{\
  const [activeModule, setActiveModule] = useState('invoice'); \
  const [sidebarOpen, setSidebarOpen] = useState(false);\
  const [user, setUser] = useState(null);\
  const [toastMessage, setToastMessage] = useState('');\
\
  const showToast = (msg) => \{\
    setToastMessage(msg);\
    setTimeout(() => setToastMessage(''), 3000);\
  \};\
\
  useEffect(() => \{\
    const initAuth = async () => \{\
      try \{\
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) await signInWithCustomToken(auth, __initial_auth_token);\
        else await signInAnonymously(auth);\
      \} catch (err) \{ console.error(err); \}\
    \};\
    initAuth();\
    const unsubscribe = onAuthStateChanged(auth, setUser);\
    return () => unsubscribe();\
  \}, []);\
\
  return (\
    <div className="flex h-screen bg-slate-100 font-sans text-slate-900 overflow-hidden">\
      \
      \{/* Toast Notification */\}\
      \{toastMessage && (\
        <div className="fixed bottom-6 right-6 bg-slate-800 text-white px-6 py-3 rounded-lg shadow-lg z-50 flex items-center gap-3 animate-bounce print:hidden">\
            <CheckCircle2 className="w-5 h-5 text-emerald-400" />\
            <span className="font-medium text-sm">\{toastMessage\}</span>\
        </div>\
      )\}\
\
      \{/* Mobile Sidebar Overlay */\}\
      \{sidebarOpen && (\
        <div className="fixed inset-0 bg-slate-900/50 z-40 lg:hidden" onClick=\{() => setSidebarOpen(false)\} />\
      )\}\
\
      \{/* Main Sidebar */\}\
      <aside className=\{`fixed lg:static top-0 left-0 h-full w-64 bg-slate-900 text-white z-50 flex flex-col transition-transform duration-300 ease-in-out $\{sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'\} print:hidden`\}>\
        <div className="p-6 border-b border-slate-800 flex items-center gap-3">\
          <div className="flex items-center justify-center w-10 h-10 bg-orange-500 rounded-full border-2 border-orange-600 shadow-md relative text-white shrink-0">\
            <span className="absolute top-[2px] text-[5px] font-black tracking-widest uppercase">Quick</span>\
            <span className="absolute bottom-[2px] text-[5px] font-black tracking-widest uppercase">Box</span>\
            <Truck className="w-5 h-5 mb-0.5" />\
          </div>\
          <div>\
            <h1 className="text-xl font-black tracking-tight leading-none text-white">QUICK BOX</h1>\
            <h2 className="text-[10px] font-bold text-orange-500 tracking-widest uppercase">Management</h2>\
          </div>\
        </div>\
\
        <nav className="flex-1 px-4 py-6 space-y-2">\
          <div className="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3 px-2">Dashboards</div>\
          \
          <button \
            onClick=\{() => \{ setActiveModule('kitchen'); setSidebarOpen(false); \}\}\
            className=\{`w-full flex items-center gap-3 px-4 py-3 rounded-xl font-bold transition-colors $\{activeModule === 'kitchen' ? 'bg-orange-500 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white'\}`\}\
          >\
            <ChefHat className="w-5 h-5" /> Kitchen Costing\
          </button>\
          \
          <button \
            onClick=\{() => \{ setActiveModule('invoice'); setSidebarOpen(false); \}\}\
            className=\{`w-full flex items-center gap-3 px-4 py-3 rounded-xl font-bold transition-colors $\{activeModule === 'invoice' ? 'bg-orange-500 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white'\}`\}\
          >\
            <Receipt className="w-5 h-5" /> Billing & Invoices\
          </button>\
          \
          <button \
            onClick=\{() => \{ setActiveModule('delivery'); setSidebarOpen(false); \}\}\
            className=\{`w-full flex items-center gap-3 px-4 py-3 rounded-xl font-bold transition-colors $\{activeModule === 'delivery' ? 'bg-orange-500 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white'\}`\}\
          >\
            <MapPin className="w-5 h-5" /> Delivery Tracker\
          </button>\
        </nav>\
\
        <div className="p-6 border-t border-slate-800 bg-slate-900/50">\
          <div className="flex items-center gap-2 text-xs font-medium text-slate-500">\
             <Store className="w-4 h-4 text-emerald-500"/>\
             System Status: <span className="text-emerald-500 font-bold">Online</span>\
          </div>\
        </div>\
      </aside>\
\
      \{/* Main App Content Area */\}\
      <main className="flex-1 flex flex-col h-screen overflow-hidden min-w-0 relative bg-slate-100">\
        \{/* Mobile Header */\}\
        <div className="lg:hidden bg-slate-900 text-white p-4 flex justify-between items-center print:hidden shrink-0">\
            <div className="flex items-center gap-2 font-black text-lg"><Truck className="w-5 h-5 text-orange-500"/> QUICK BOX</div>\
            <button onClick=\{() => setSidebarOpen(true)\} className="p-2 bg-slate-800 rounded-lg"><Menu className="w-5 h-5"/></button>\
        </div>\
\
        \{/* Modules loaded via CSS hidden classes to preserve UI state when switching tabs */\}\
        <div className=\{`flex-1 overflow-hidden $\{activeModule === 'kitchen' ? 'flex flex-col' : 'hidden'\}`\}>\
            <KitchenModule user=\{user\} showToast=\{showToast\} />\
        </div>\
        <div className=\{`flex-1 overflow-hidden $\{activeModule === 'invoice' ? 'flex flex-col' : 'hidden'\}`\}>\
            <InvoiceModule user=\{user\} showToast=\{showToast\} />\
        </div>\
        <div className=\{`flex-1 overflow-hidden $\{activeModule === 'delivery' ? 'flex flex-col' : 'hidden'\}`\}>\
            <DeliveryModule user=\{user\} showToast=\{showToast\} />\
        </div>\
      </main>\
\
    </div>\
  );\
\};\
\
export default App;}